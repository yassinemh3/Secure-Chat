# ──────────────────────────────────────────────────────────────────────────────
# Secure-Chat Environment Variables
# Copy this file to .env and fill in your values before running docker-compose
# ──────────────────────────────────────────────────────────────────────────────

# Database
POSTGRES_DB=securechat
POSTGRES_USER=securechat
POSTGRES_PASSWORD=change_me_in_production

# JWT — must be at least 32 characters, random and secret
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost
WS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost

# Server
SERVER_PORT=8080
